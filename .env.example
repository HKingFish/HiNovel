# ========================================================
# HiNovel AI 小说创作平台 - 环境变量配置
# 复制此文件为 .env，填写真实配置后启动服务
# 注意：.env 文件已加入 .gitignore，请勿提交到版本库
# ========================================================

# ============================================================
# 数据库配置（MySQL 8.x）
# ============================================================
# 本地开发时填写远程数据库地址，Docker 部署时由 docker-compose 覆盖为容器服务名
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=hinovel_platform
MYSQL_USER=root
# 必填项，无默认值，未配置时应用启动失败
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=

# ============================================================
# Redis 配置
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
# Redis 密码（留空则无密码）
REDIS_PASSWORD=

# ============================================================
# Qdrant 向量数据库配置
# ============================================================
# 本地开发时填写远程地址，Docker 部署时由 docker-compose 覆盖
QDRANT_HOST=localhost
# gRPC 端口（Java 客户端使用 gRPC 协议连接）
QDRANT_PORT=6334
# 宿主机端口映射（仅 docker-compose 使用）
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# ============================================================
# 服务端口配置
# ============================================================
SERVER_PORT=8080
WEB_PORT=80

# ============================================================
# OSS 文件存储配置
# ============================================================
# 存储类型：LOCAL（本地存储）或 ALIYUN（阿里云 OSS）
OSS_TYPE=LOCAL

# 本地存储配置（OSS_TYPE=LOCAL 时生效）
OSS_LOCAL_URL_PREFIX=http://localhost:8080/files

# 阿里云 OSS 配置（OSS_TYPE=ALIYUN 时必填）
OSS_ALIYUN_ENDPOINT=
OSS_ALIYUN_ACCESS_KEY_ID=
OSS_ALIYUN_ACCESS_KEY_SECRET=
OSS_ALIYUN_BUCKET_NAME=

# ============================================================
# Docker 镜像加速（国内无法直连 Docker Hub 时取消注释）
# ============================================================
# 官方镜像使用 library/ 前缀，第三方镜像如 qdrant 不含 library
# DOCKER_IMAGE_MYSQL=docker.m.daocloud.io/library/mysql:8.0
# DOCKER_IMAGE_REDIS=docker.m.daocloud.io/library/redis:7.2-alpine
# DOCKER_IMAGE_QDRANT=docker.m.daocloud.io/qdrant/qdrant:v1.12.5
# DOCKER_IMAGE_MAVEN=docker.m.daocloud.io/library/maven:3.9.6-eclipse-temurin-21
# DOCKER_IMAGE_JRE=docker.m.daocloud.io/library/eclipse-temurin:21-jre-alpine
# DOCKER_IMAGE_NGINX=docker.m.daocloud.io/library/nginx:1.25-alpine

# ============================================================
# 安全配置
# ============================================================
# API 密钥加密密钥（AES-128，至少 16 个字符，必填项，无默认值）
API_KEY_SECRET=
