{
  "name": "hinovel-web",
  "version": "1.0.0",
  "description": "HiNovel AI 小说创作平台前端",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/HKingFish/HiNovel.git"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest --run",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.{ts,vue}",
    "lint:fix": "eslint src/**/*.{ts,vue} --fix",
    "format": "prettier --write src/**/*.{ts,vue,scss,css}",
    "prepare": "cd .. && husky"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@tiptap/core": "^3.22.2",
    "@tiptap/extension-character-count": "^3.22.2",
    "@tiptap/extension-highlight": "^3.22.2",
    "@tiptap/extension-placeholder": "^3.22.2",
    "@tiptap/pm": "^3.22.2",
    "@tiptap/starter-kit": "^3.22.2",
    "@tiptap/vue-3": "^3.22.2",
    "axios": "^1.7.0",
    "echarts": "^6.0.0",
    "element-plus": "^2.7.0",
    "marked": "^12.0.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/ui": "^1.6.0",
    "@vue/test-utils": "^2.4.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "husky": "^9.1.7",
    "jsdom": "^24.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.57.2",
    "unplugin-auto-import": "^0.17.0",
    "unplugin-vue-components": "^0.27.0",
    "vite": "^5.2.0",
    "vitest": "^1.6.0",
    "vue-tsc": "^2.0.0"
  },
  "lint-staged": {
    "src/**/*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{scss,css}": [
      "prettier --write"
    ]
  }
}
